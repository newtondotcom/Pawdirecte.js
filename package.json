{
  "name": "pawdirecte-teacher",
  "version": "2.2.2",
  "description": "A purrfect API wrapper for EcoleDirecte for teachers.",
  "repository": "https://github.com/newtondotcom/Pawdirecte.js",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "checks": "tsc && eslint .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ecoledirecte",
    "wrapper",
    "api"
  ],
  "author": "Newton (https://github.com/newtondotcom)",
  "homepage": "https://github.com/newtondotcom/Pawdirecte.js",
  "bugs": {
    "url": "https://github.com/newtondotcom/Pawdirecte.js/issues"
  },
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "dotenv": "^16.6.1",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "terser": "^5.44.1",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "cookie-es": "^2.0.0",
    "js-base64": "^3.7.8"
  }
}
